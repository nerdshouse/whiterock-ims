rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Require auth for all collections
    match /warehouses/{id} {
      allow read, write: if request.auth != null;
    }
    match /skus/{id} {
      allow read, write: if request.auth != null;
    }
    match /stock/{id} {
      allow read, write: if request.auth != null;
    }
    match /purchaseOrders/{id} {
      allow read, write: if request.auth != null;
    }
    match /stockMovements/{id} {
      allow read, write: if request.auth != null;
    }
    match /members/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
